# Ember Secrets Template
# IMPORTANT: Do not commit real secrets! Use kubectl create secret or external secrets manager.
apiVersion: v1
kind: Secret
metadata:
  name: ember-secrets
  namespace: ember
  labels:
    app.kubernetes.io/name: ember
type: Opaque
stringData:
  # Database connection
  database-url: "sqlite:///data/ember.db"
  
  # LLM Provider API Keys (replace with actual values)
  # openai-api-key: "sk-..."
  # anthropic-api-key: "sk-ant-..."
  # google-api-key: "..."
  # groq-api-key: "gsk_..."
  # deepseek-api-key: "..."
  # mistral-api-key: "..."
  # openrouter-api-key: "..."
  # xai-api-key: "..."
  
  # Enterprise SSO (optional)
  # sso-client-id: "..."
  # sso-client-secret: "..."
  
  # JWT signing key
  jwt-secret: "change-me-in-production-use-openssl-rand-base64-32"